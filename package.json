{
  "name": "md-share",
  "version": "1.0.0",
  "description": "application for share Markdown files",
  "author": "donBarbos <donbarbos@proton.me> (https://dontkillkenny.com)",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/donBarbos/md-share"
  },
  "keywords": [
    "md-share",
    "markdown",
    "react",
    "gatsby"
  ],
  "scripts": {
    "develop": "gatsby develop",
    "start": "gatsby develop",
    "build": "gatsby build",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "lint": "eslint --ignore-path .gitignore . --ext ts --ext tsx --ext js --ext jsx",
    "lint:fix": "yarn lint --fix",
    "prettier": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "husky install"
  },
  "husky": {
    "hooks": {
      "pre-commit": [
        "yarn typecheck && yarn lint-staged"
      ]
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "yarn lint:fix",
      "git add"
    ],
    "*.scss": [
      "prettier --write",
      "stylelint --fix",
      "git add"
    ],
    "{*.{json,md}}": [
      "prettier --write",
      "git add"
    ]
  },
  "dependencies": {
    "babel-plugin-styled-components": "^2.0.7",
    "gatsby": "^4.18.2",
    "gatsby-plugin-catch-links": "^4.18.0",
    "gatsby-plugin-image": "^2.19.0",
    "gatsby-plugin-manifest": "^4.18.1",
    "gatsby-plugin-offline": "^5.19.0",
    "gatsby-plugin-react-helmet": "^5.19.0",
    "gatsby-plugin-robots-txt": "^1.7.1",
    "gatsby-plugin-sharp": "^4.19.0",
    "gatsby-plugin-sitemap": "^5.19.0",
    "gatsby-plugin-styled-components": "^5.19.0",
    "gatsby-plugin-typography": "^4.19.0",
    "gatsby-source-filesystem": "^4.18.1",
    "gatsby-transformer-remark": "^5.19.0",
    "gatsby-transformer-sharp": "^4.18.1",
    "react": "^18.1.0",
    "react-dom": "^18.1.0",
    "react-feather": "^2.0.10",
    "react-helmet": "^6.1.0",
    "react-typography": "^0.16.20",
    "styled-components": "^5.3.5",
    "typography": "^0.16.21"
  },
  "devDependencies": {
    "@types/node": "^18.0.6",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^18.0.6",
    "@types/react-helmet": "^6.1.5",
    "@types/styled-components": "^5.1.25",
    "@types/typography": "^0.16.4",
    "@typescript-eslint/eslint-plugin": "^5.30.7",
    "@typescript-eslint/parser": "^5.30.6",
    "eslint": "^8.20.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jsx-a11y": "^6.6.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.30.1",
    "husky": "^8.0.1",
    "lint-staged": "^13.0.3",
    "prettier": "^2.7.1",
    "typescript": "^4.7.4"
  }
}
